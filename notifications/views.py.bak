# ==================== API ENDPOINTS ====================

@login_required
@require_http_methods(["POST"])
def mark_as_read(request, notification_id):
    """Mark a single notification as read (Existing code)"""
    try:
        notification = get_object_or_404(Notification, id=notification_id, user=request.user)
        notification.is_read = True
        notification.read_at = timezone.now()
        notification.save()
        return JsonResponse({'success': True})
    except Exception as e:
        return JsonResponse({'success': False, 'error': str(e)}, status=400)


@login_required
@require_http_methods(["POST"])
def mark_all_read(request):
    """Mark all notifications as read (Existing code)"""
    try:
        updated = Notification.objects.filter(user=request.user, is_read=False).update(
            is_read=True, 
            read_at=timezone.now()
        )
        return JsonResponse({'success': True, 'count': updated})
    except Exception as e:
        return JsonResponse({'success': False, 'error': str(e)}, status=400)

# notifications/views.py - Updated api_notifications function
@login_required
def api_notifications(request):
    """API endpoint for notifications (AJAX)"""
    # Get all notifications for the current user
    notifications = Notification.objects.filter(user=request.user).order_by('-created_at')
    
    # Get limit parameter
    try:
        limit = int(request.GET.get('limit', 50))
    except ValueError:
        limit = 50
    
    # Apply limit
    notifications = notifications[:limit]
    
    # Prepare data - NO extra fields
    data = []
    for n in notifications:
        data.append({
            'id': n.id,
            'title': n.title,
            'message': n.message,
            'type': n.notification_type,
            'priority': n.priority,
            'priority_display': n.get_priority_display(),
            'is_read': n.is_read,
            'time_ago': n.time_ago,
            'created_at': n.created_at.isoformat() if n.created_at else None,
            'link': n.link,
        })
    
    # Get unread count
    unread_count = Notification.objects.filter(user=request.user, is_read=False).count()
    
    return JsonResponse({
        'success': True,
        'notifications': data,
        'unread_count': unread_count,
        'total': notifications.count()
    })

@login_required
def api_notification_stats(request):
    """Get notification statistics (API) (Existing code)"""
    total = Notification.objects.filter(user=request.user).count()
    unread = Notification.objects.filter(user=request.user, is_read=False).count()
    read = total - unread
    urgent = Notification.objects.filter(user=request.user, priority='urgent', is_read=False).count()
    
    # Get counts by type
    by_type = {}
    type_counts = Notification.objects.filter(user=request.user).values('notification_type').annotate(count=Count('id'))
    for item in type_counts:
        by_type[item['notification_type']] = item['count']
    
    # Get counts by priority
    by_priority = {}
    priority_counts = Notification.objects.filter(user=request.user).values('priority').annotate(count=Count('id'))
    for item in priority_counts:
        by_priority[item['priority']] = item['count']
    
    stats = {
        'total': total,
        'unread': unread,
        'read': read,
        'urgent': urgent,
        'by_type': by_type,
        'by_priority': by_priority,
    }
    
    return JsonResponse(stats)


@login_required
@require_http_methods(["POST"])
def delete_notification(request, notification_id):
    """Delete a notification (Existing code)"""
    if not is_admin_or_ceo(request.user):
        return JsonResponse({'error': 'Permission denied'}, status=403)
    
    try:
        notification = get_object_or_404(Notification, id=notification_id)
        notification.delete()
        return JsonResponse({'success': True})
    except Exception as e:
        return JsonResponse({'success': False, 'error': str(e)}, status=400)


@login_required
def get_template_api(request, template_id):
    """Get template details (API) (Existing code)"""
    template = get_object_or_404(NotificationTemplate, id=template_id)
    return JsonResponse({
        'title': template.title,
        'message': template.message,
        'notification_type': template.notification_type,
        'priority': template.priority
    })


# ==================== USER SETTINGS ====================

@login_required
def notification_settings(request):
    """User notification preferences (Existing code)"""
    settings, created = UserNotificationSettings.objects.get_or_create(user=request.user)
    
    if request.method == 'POST':
        settings.email_notifications = request.POST.get('email_notifications') == 'on'
        settings.sms_notifications = request.POST.get('sms_notifications') == 'on'
        settings.push_notifications = request.POST.get('push_notifications') == 'on'
        settings.whatsapp_notifications = request.POST.get('whatsapp_notifications') == 'on'
        
        settings.notify_payment = request.POST.get('notify_payment') == 'on'
        settings.notify_loan = request.POST.get('notify_loan') == 'on'
        settings.notify_reminder = request.POST.get('notify_reminder') == 'on'
        settings.notify_alert = request.POST.get('notify_alert') == 'on'
        settings.notify_promotion = request.POST.get('notify_promotion') == 'on'
        settings.notify_system = request.POST.get('notify_system') == 'on'
        
        settings.save()
        messages.success(request, 'Notification preferences updated!')
        return redirect('notifications:settings')
    
    context = {'settings': settings}
    return render(request, 'notifications/settings.html', context)



# .env - Korata Lending System Environment Variables

# ==================== DJANGO CORE SETTINGS ====================
# Django Secret Key - Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Debug Mode - Set to False in production
DJANGO_DEBUG=True

# Allowed Hosts - Comma-separated list
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.ngrok-free.dev

# CSRF Trusted Origins - Comma-separated list
CSRF_TRUSTED_ORIGINS=https://*.onrender.com,https://*.ngrok-free.dev

# Site URL
SITE_URL=http://127.0.0.1:8000

# ==================== DATABASE SETTINGS ====================
# PostgreSQL (Production - Render)
DATABASE_URL=postgresql://username:password@host:port/database_name

# SQLite (Development - Local)
# DB_NAME=korata_lending.db
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# ==================== EMAIL SETTINGS ====================
# Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=Korata Lending <noreply@korata.com>

# SendGrid (Alternative)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# ==================== AI SETTINGS ====================
# Ollama (Local - Free)
OLLAMA_MODEL=tinyllama  # Options: tinyllama, llama2, mistral, phi, gemma
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (Cloud - Paid, Optional fallback)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo  # or gpt-4

# ==================== SMS SETTINGS ====================
# Africa's Talking (Primary - Best for Africa)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-africastalking-api-key
SMS_SHORTCODE=12345
SMS_SENDER_ID=Korata

# Twilio (Backup)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MessageBird (Alternative)
MESSAGEBIRD_API_KEY=your-messagebird-api-key

# SMS Rate Limits
SMS_RATE_LIMIT_PER_MINUTE=10
SMS_RATE_LIMIT_PER_DAY=100

# ==================== REDIS SETTINGS (Optional) ====================
# For caching and background tasks
REDIS_URL=redis://localhost:6379

# ==================== FILE STORAGE (Optional) ====================
# AWS S3 for media files (Production)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=korata-media
# AWS_S3_REGION_NAME=us-east-1

# ==================== SECURITY SETTINGS ====================
# Session timeout (in seconds)
SESSION_COOKIE_AGE=1500
IDLE_TIMEOUT_SECONDS=120

# Rate limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=300

# ==================== SUPPORT CONTACT ====================
SUPPORT_PHONE=+260123456789
SUPPORT_EMAIL=support@korata.com
SUPPORT_SMS_NUMBER=12345

# ==================== FEATURE FLAGS ====================
ENABLE_AI_CHAT=True
ENABLE_SMS_NOTIFICATIONS=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_BACKUP_AUTOMATION=False

# ==================== LOGGING ====================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO